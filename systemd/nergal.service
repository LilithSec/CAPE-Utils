[Unit]
Description=Listen on HTTP or HTTPS and submit stuff to CAPEv2
After=syslog.target network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=cape
Group=cape
EnvironmentFile=/usr/local/etc/nergal.env
ExecStart=/usr/local/bin/nergal daemon -m production -l $LISTEN_ON
TimeoutStartSec=300
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
